MATTERMOST_URL=https://your-mattermost-instance.example.com
MATTERMOST_TOKEN=your-bot-token

# SMTP settings for alert emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=nudge-bot@krakelee.org

# Alert recipient
ALERT_EMAIL=ak-crewcare@krakelee.org

# Path to the JSON file used to persist nudge data (defaults to ./nudges.json)
STORAGE_FILE=./nudges.json

# Number of nudges in a calendar month that trigger an alert (defaults to 5)
NUDGE_ALERT_THRESHOLD=5

# Reaction-based nudge monitor (optional)
# Comma-separated channel IDs to monitor for posts
REACTION_MONITOR_CHANNEL_IDS=
# Backward-compatible single channel ID option (use either this or CHANNEL_IDS)
# Channel ID to monitor for posts
REACTION_MONITOR_CHANNEL_ID=
# Comma-separated usernames that must react in time (e.g. alice,bob,charlie)
REACTION_MONITOR_USERS=
# Minutes allowed to react before a nudge is recorded (defaults to 60)
REACTION_TIMEOUT_MINUTES=60
